generator client {
  provider      = "prisma-client-js"
  // 含 windows：在 macOS 上打 Windows 离线包时 Prisma 引擎齐全
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  WEBMASTER
  ADMIN
}

enum DailyReportStatus {
  approved
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  passwordHash String
  role         Role
  createdAt    DateTime      @default(now())
  dailyReports DailyReport[] @relation("CreatedReports")
}

model Shift {
  id           String        @id @default(cuid())
  name         String
  sortOrder    Int
  active       Boolean       @default(true)
  dailyReports DailyReport[]
}

model ResponsiblePerson {
  id     String @id @default(cuid())
  name   String
  active Boolean @default(true)
}

model TaxFreeCardTier {
  id              String @id @default(cuid())
  denominationYen Int
  sortOrder       Int
  active          Boolean @default(true)
}

/// 单行全局设置（收银底钱等）
model AppSettings {
  id                  String  @id @default("default")
  registerFloatAmount Int     @default(0)
  setupCompleted      Boolean @default(false)
}

model DailyReport {
  id                         String @id @default(cuid())
  reportDate                 String
  shiftId                    String
  shift                      Shift  @relation(fields: [shiftId], references: [id])
  shiftNameSnapshot          String

  responsiblePersonId        String
  responsiblePersonSnapshot  String

  startMinuteOfDay           Int
  endMinuteOfDay             Int
  timeRangeLabelSnapshot     String

  /// チャージ・ナイト（税込円）— API 受信は税抜を×1.1 換算して保存
  chargeNightPackYen         Int
  /// 商品売上（税込円）
  productSalesYen            Int

  /** 券种 id → 枚数。SQLite 下 Json 的 @default 会生成非法 SQL，故省略默认值，由应用将 null 视为 {} */
  taxFreeCouponCounts        Json?

  newageYen                  Int
  airpayQrYen                Int
  /// レジ実点（底銭込）円 — ユーザー入力そのまま。偏差は本列＋他項目−総売上−底銭（設定）
  cashTotalYen               Int

  ddnPhotoKey                String?
  taxFreeCardPhotoKey        String?

  totalSalesYen              Int
  taxFreeCardAmountYen       Int
  deviationYen               Int
  deviationReason            String?

  status                     DailyReportStatus @default(approved)

  createdByUserId            String
  createdBy                  User   @relation("CreatedReports", fields: [createdByUserId], references: [id])
  updatedAt                  DateTime @updatedAt

  @@unique([reportDate, shiftId])
  @@index([reportDate])
  @@index([createdByUserId, reportDate])
}
