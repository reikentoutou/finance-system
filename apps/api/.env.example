# SQLite：路径相对于「含有 schema.prisma 的 prisma 目录」（即 apps/api/prisma/）。
# 请使用 file:./dev.db（文件落在 apps/api/prisma/dev.db）。
# 若写成 file:./prisma/dev.db，实际会指向 apps/api/prisma/prisma/dev.db，易与预期不符。
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-in-production"
JWT_EXPIRES_IN="7d"
# 生产环境（NODE_ENV=production）未设置 JWT_SECRET 时 API 会拒绝启动
# NODE_ENV=production
# 浏览器与 API 不同域时，逗号分隔允许的前端 Origin（不设则开发态等价于 reflect 任意来源）
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
UPLOAD_DIR="./uploads"
PORT=3000
# 仅桌面打包版：Electron 拉起静态页端口（与 PORT 不可相同）
WEB_STATIC_PORT=5173
TZ=Asia/Tokyo
