{
  "name": "@finance/desktop",
  "version": "0.0.3",
  "private": true,
  "main": "main.js",
  "author": "Finance System",
  "description": "Finance system desktop shell (Windows x64)",
  "scripts": {
    "start": "electron .",
    "pack:win": "electron-builder --win --x64",
    "pack:win:portable": "electron-builder --win portable --x64"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.finance.system.desktop",
    "productName": "FinanceSystem",
    "files": ["main.js", "package.json"],
    "extraResources": [
      {
        "from": "resources-bundled",
        "to": "bundled",
        "filter": ["**/*"]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-Windows-Setup-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Windows-Portable-${arch}.${ext}"
    }
  }
}
